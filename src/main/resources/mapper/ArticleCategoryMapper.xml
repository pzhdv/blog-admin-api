<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.pzhdv.blog.mapper.ArticleCategoryMapper">


    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="cn.pzhdv.blog.entity.ArticleCategory">
        <id column="category_id" property="categoryId"/>
        <result column="category_name" property="categoryName"/>
        <result column="parent_id" property="parentId"/>
        <result column="icon_class" property="iconClass"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        category_id
        , category_name, parent_id, icon_class
    </sql>
    <select id="queryArticleCategoryPieChart" resultType="cn.pzhdv.blog.vo.category.CategoryPieChartVO">
        SELECT
            c.category_name,
            COUNT( r.article_id ) AS article_count
        FROM
            article_category c
                LEFT JOIN article_category_relation r ON c.category_id = r.category_id
        WHERE
            c.parent_id IS NOT NULL
          AND c.category_id != 1
	AND NOT EXISTS ( SELECT 1 FROM article_category c2 WHERE c2.parent_id = c.category_id )
        GROUP BY
            c.category_id,
            c.category_name
        ORDER BY
            article_count DESC;
    </select>

</mapper>
